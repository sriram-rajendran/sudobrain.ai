# Copy this file to .env and fill only the integrations you want to enable.
# Keep .env private. It is intentionally ignored by Git.

# Core API
SUDOBRAIN_API_TOKEN=
SUDOBRAIN_TRUST_LOCALHOST=true
SUDOBRAIN_DATA_DIR=./local-data
SUDOBRAIN_PROJECT_DIR=.

# Local model provider
SUDOBRAIN_LLM_COMMAND=
SUDOBRAIN_LLM_PROVIDER=ollama
SUDOBRAIN_LLM_MODEL=gemma4:e4b
OLLAMA_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434

# Optional opt-in model providers. Leave unset for local-first mode.
SUDOBRAIN_OPENAI_COMPAT_BASE_URL=
SUDOBRAIN_OPENAI_COMPAT_MODEL=
SUDOBRAIN_OPENAI_COMPAT_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_API_KEY=
GROQ_MODEL=
AWS_PROFILE=
BEDROCK_MODEL=
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=sudobrain

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sudobrain
NEO4J_AUTH=neo4j/sudobrain

# Optional transcription / meeting integrations
SARVAM_API_KEY=
FATHOM_API_TOKEN=
FATHOM_WEBHOOK_SECRET=

# Optional read-only source integrations
SLACK_USER_TOKEN=
LINEAR_API_TOKEN=
GMAIL_CREDENTIALS_FILE=./credentials.json
GMAIL_TOKEN_FILE=./token.json
GCAL_TOKEN_FILE=./gcal_token.json

# Source sync toggles
SUDOBRAIN_SYNC_GMAIL=false
SUDOBRAIN_SYNC_SLACK=false
SUDOBRAIN_SYNC_FATHOM=false
SUDOBRAIN_SYNC_PROJECT_CONTEXT=false
SUDOBRAIN_SLACK_INCLUDE_DMS=false
SUDOBRAIN_SLACK_EXTRACT_KNOWLEDGE=false
SUDOBRAIN_OTEL_ENABLED=false
SUDOBRAIN_PLUGIN_PATHS=
SUDOBRAIN_MCP_CONFIG=~/.sudobrain/mcp_servers.json
SUDOBRAIN_AUTH_MODE=local_single_user
SUDOBRAIN_LOCAL_ROLE=owner
SUDOBRAIN_SSO_ISSUER=
SUDOBRAIN_SSO_CLIENT_ID=
SUDOBRAIN_SECRET_BACKEND=environment
SUDOBRAIN_SECRETS_KEY=
SUDOBRAIN_QUOTA_API_REQUESTS=600
SUDOBRAIN_QUOTA_PROVIDER_TESTS=30
SUDOBRAIN_QUOTA_SYNC_RUNS=12

# Optional local repository context.
# Set this to a folder containing repositories you want SudoBrain to index.
SUDOBRAIN_PROJECTS_ROOT=

# Optional JSON configuration for aliases and canonical names.
# See docs/setup.md for examples.
SUDOBRAIN_PROJECT_ALIASES_JSON={}
SUDOBRAIN_RESERVED_ALIAS_OWNERS_JSON={}
SUDOBRAIN_PROJECT_PATTERNS_JSON={}
SUDOBRAIN_PERSON_ALIASES_JSON={}
SUDOBRAIN_EMAIL_NAME_OVERRIDES_JSON={}
SUDOBRAIN_SLACK_ID_OVERRIDES_JSON={}
SUDOBRAIN_ACCEPTED_EXTERNAL_PROJECTS=
SUDOBRAIN_REQUIRED_PROJECTS=
SUDOBRAIN_STRICT_PROJECT_AUDIT=false
SUDOBRAIN_COMMIT_RISK_KEYWORDS_JSON={}
SUDOBRAIN_PROJECT_KEYWORDS=
SUDOBRAIN_INTERNAL_EMAIL_DOMAINS=
SELF_EMAIL=
